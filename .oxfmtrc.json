{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "bracketSameLine": true,
    "overrides": [
        {
            "files": ["*.yaml"],
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": ["*.yaml"],
            "options": {
                "singleQuote": true
            }
        }
    ],
    "tabWidth": 4
}
